{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    { "path": "/api/cron?job=sweep",     "schedule": "0 0 * * *"  },
    { "path": "/api/cron?job=marketing", "schedule": "0 10 * * *" },
    { "path": "/api/cron?job=winback",   "schedule": "0 11 * * *" },
    { "path": "/api/cron?job=reminders", "schedule": "0 16 * * *" }
  ],
  "redirects": [
    { "source": "/writing",              "destination": "/celpip-writing-practice",       "permanent": true },
    { "source": "/writing/:path*",       "destination": "/celpip-writing-practice/:path*","permanent": true },
    { "source": "/speaking",             "destination": "/celpip-speaking-practice",      "permanent": true },
    { "source": "/speaking/:path*",      "destination": "/celpip-speaking-practice/:path*","permanent": true },
    { "source": "/reading",              "destination": "/celpip-reading-practice",       "permanent": true },
    { "source": "/reading/:path*",       "destination": "/celpip-reading-practice/:path*","permanent": true },
    { "source": "/listening",            "destination": "/celpip-listening-practice",     "permanent": true },
    { "source": "/listening/:path*",     "destination": "/celpip-listening-practice/:path*","permanent": true },
    { "source": "/calculator",           "destination": "/crs-score-calculator",          "permanent": true },
    { "source": "/tips",                 "destination": "/celpip-resources",              "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
