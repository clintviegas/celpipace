# Supabase (public — safe for browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CDN for audio/images (Cloudflare R2 public URL)
# Leave empty for local dev (serves from /public)
# Example: https://assets.celpipace.com
VITE_CDN_URL=

# OpenAI
OPENAI_API_KEY=

# ── Stripe (server-side only — NEVER prefix with VITE_) ──────────────────────
# Stripe secret key — Dashboard → Developers → API keys
# Use sk_test_... for local dev, sk_live_... in Vercel production
STRIPE_SECRET_KEY=

# Webhook signing secret — Dashboard → Developers → Webhooks → Signing secret
# For local dev use: stripe listen --forward-to localhost:5173/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — Dashboard → Products → (your product) → price_... IDs
STRIPE_PRICE_WEEKLY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=

# Supabase service-role key (bypasses RLS — server-side only, never expose to browser)
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Your public site URL (no trailing slash)
# Local: http://localhost:5173   Production: https://celpipace.com
PUBLIC_SITE_URL=

# ── Resend (transactional email) ─────────────────────────────────────────────
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address — must be on a domain you've verified in Resend
# Example: 'CELPIPACE <info@celpipace.ca>'
EMAIL_FROM=

# ── Playwright E2E (only needed locally for `npm run e2e`) ───────────────────
# A signed-in test account that can run the cancellation flow.
E2E_BASE_URL=http://localhost:5173
E2E_EMAIL=
E2E_PASSWORD=
