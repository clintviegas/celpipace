# Supabase (public — safe for browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CDN for audio/images (Cloudflare R2 public URL)
# Leave empty for local dev (serves from /public)
# Example: https://assets.celpipace.com
VITE_CDN_URL=

# OpenAI
OPENAI_API_KEY=

# ── Stripe (server-side only — NEVER prefix with VITE_) ──────────────────────
# Stripe secret key — Dashboard → Developers → API keys
# Use sk_test_... for local dev, sk_live_... in Vercel production
STRIPE_SECRET_KEY=

# Webhook signing secret — Dashboard → Developers → Webhooks → Signing secret
# For local dev use: stripe listen --forward-to localhost:5173/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — Dashboard → Products → (your product) → price_... IDs
STRIPE_PRICE_WEEKLY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=

# Supabase service-role key (bypasses RLS — server-side only, never expose to browser)
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Your public site URL (no trailing slash)
# Local: http://localhost:5173   Production: https://celpipace.com
PUBLIC_SITE_URL=

# ── Brevo (transactional + lifecycle email automation) ───────────────────────
# API key — Brevo Dashboard → Settings → API Keys
BREVO_API_KEY=

# Verified sender address — must match a domain verified in Brevo → Senders & IP → Domains
# Example: 'CELPIPACE <hello@celpipace.ca>'
EMAIL_FROM=

# List IDs — Brevo Dashboard → Contacts → Lists → click list → ID in the URL
BREVO_LIST_ID=           # Main "CELPIPACE Users" list (signup drip trigger)
BREVO_LIST_PREMIUM=      # "Premium" list (onboarding trigger on subscribe)
BREVO_LIST_CANCELLED=    # "Cancelled" list (win-back trigger on cancel)

# ── Marketing campaigns ──────────────────────────────────────────────────────
# Resend Audience UUID — Resend Dashboard → Audiences → New audience
# Required for marketing-consent sync + future broadcasts.
RESEND_AUDIENCE_ID=

# CASL-required physical mailing address shown in marketing email footers.
# Example: 'CELPIPACE, 123 King St W, Toronto, ON M5H 1A1, Canada'
MAILING_ADDRESS=

# Stateless HMAC secret for one-click unsubscribe tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, falls back to SUPABASE_SERVICE_ROLE_KEY (works but rotate together).
UNSUBSCRIBE_SECRET=

# Vercel cron auth — set the same value in Vercel project settings.
# Falsy → cron endpoints are unauthenticated (dev only).
CRON_SECRET=

# ── Playwright E2E (only needed locally for `npm run e2e`) ───────────────────
# A signed-in test account that can run the cancellation flow.
E2E_BASE_URL=http://localhost:5173
E2E_EMAIL=
E2E_PASSWORD=
